{
  "name": "SJ's Morning Briefing",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 7 * * *"
            }
          ]
        }
      },
      "name": "Wake Up (7 AM)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [0, 0],
      "typeVersion": 1
    },
    {
      "parameters": {
        "url": "https://api.open-meteo.com/v1/forecast?latitude=-45.8742&longitude=170.5036&daily=weather_code,temperature_2m_max,temperature_2m_min&timezone=Pacific%2FAuckland&forecast_days=1",
        "options": {}
      },
      "name": "Fetch Weather (Dunedin)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [200, 0],
      "typeVersion": 4.1
    },
    {
      "parameters": {
        "fileName": "=/vault/SJ_Diary_{{$now.minus({'days':1}).format('yyyy-MM-dd')}}.md"
      },
      "name": "Read Yesterday's Diary",
      "type": "n8n-nodes-base.readWriteFile",
      "position": [400, 0],
      "typeVersion": 1,
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:11434/api/generate",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "llama3"
            },
            {
              "name": "prompt",
              "value": "=You are a supportive, autonomous ambient intelligence assistant providing a morning briefing to SJ.\n\nToday's Weather: Max {{$('Fetch Weather (Dunedin)').item.json.daily.temperature_2m_max[0]}}°C, Min {{$('Fetch Weather (Dunedin)').item.json.daily.temperature_2m_min[0]}}°C.\nYesterday's Diary Context:\n{{$json.data || 'No diary entry yesterday.'}}\n\nTask: Write a concise, 3-sentence morning briefing for her. Be encouraging. Mention the weather and reflect warmly on a key theme from her diary if it exists. Do not include any conversational filler like 'Here is your briefing'."
            },
            {
              "name": "stream",
              "value": "false"
            }
          ]
        },
        "options": {}
      },
      "name": "Ollama Brain",
      "type": "n8n-nodes-base.httpRequest",
      "position": [600, 0],
      "typeVersion": 4.1
    },
    {
      "parameters": {
        "chatId": "8309108979",
        "text": "={{ JSON.parse($json.response).response }}",
        "additionalFields": {}
      },
      "name": "Telegram (Send to SJ)",
      "type": "n8n-nodes-base.telegram",
      "position": [800, 0],
      "typeVersion": 1
    }
  ],
  "connections": {
    "Wake Up (7 AM)": {
      "main": [
        [
          {
            "node": "Fetch Weather (Dunedin)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Weather (Dunedin)": {
      "main": [
        [
          {
            "node": "Read Yesterday's Diary",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Read Yesterday's Diary": {
      "main": [
        [
          {
            "node": "Ollama Brain",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Ollama Brain": {
      "main": [
        [
          {
            "node": "Telegram (Send to SJ)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  }
}
